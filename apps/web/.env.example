# ── Backend API ──────────────────────────────────────────────────────────────
# Browser-visible API base. Keep as the same-origin proxy path; Next rewrites
# /api/backend/* → the backend, so the httpOnly refresh cookie stays first-party.
NEXT_PUBLIC_API_URL=/api/backend

# Server-side proxy target for the Next rewrite. In dev this is the local API;
# in production (Vercel) set this to the deployed backend origin, e.g.:
#   https://ceboard-api.onrender.com
API_PROXY_TARGET=http://localhost:3001

# ── Branding ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=CE Board Master
