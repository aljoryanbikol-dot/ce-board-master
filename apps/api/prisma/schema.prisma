  title           String   @unique
  authors         String[]
  edition         String?  @db.VarChar(50)
  publisher       String?  @db.VarChar(255)
  publicationYear Int?     @map("publication_year") @db.SmallInt
  isbn13          String?  @unique @db.Char(13) @map("isbn_13")
  isbn10          String?  @unique @db.Char(10) @map("isbn_10")
  subjectArea     String?  @db.VarChar(100) @map("subject_area")
  coverImageUrl   String?  @map("cover_image_url")
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  questionReferences QuestionReference[]

  @@map("reference_books")
}

/// Junction: question ↔ reference book with page granularity.
model QuestionReference {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId      String @db.Uuid @map("question_id")
  referenceBookId String @db.Uuid @map("reference_book_id")
