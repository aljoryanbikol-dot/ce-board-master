/// Junction: question ↔ formula with usage context.
model QuestionFormula {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId  String  @db.Uuid @map("question_id")
  formulaId   String  @db.Uuid @map("formula_id")
  usageNote   String? @map("usage_note")
  stepNumber  Int?    @map("step_number") @db.SmallInt
