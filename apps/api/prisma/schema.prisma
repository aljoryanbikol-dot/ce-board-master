  question      Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  referenceBook ReferenceBook @relation(fields: [referenceBookId], references: [id], onDelete: Restrict)

  @@unique([questionId, referenceBookId])
  @@index([referenceBookId])
  @@map("question_references")
}

/// Engineering formula catalog with structured variable definitions.
model FormulaLibrary {
