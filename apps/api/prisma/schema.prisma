/// Flexible keyword tags for cross-cutting question classification.
model Tag {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @unique @db.VarChar(100)
  slug        String      @unique @db.VarChar(80)
  category    TagCategory @default(general)
  description String?
  colorHex    String?     @db.Char(7) @map("color_hex")
  usageCount  Int         @default(0) @map("usage_count")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  questionTags QuestionTag[]

  @@index([category])
  @@map("tags")
}

/// Junction: tag ↔ question.
model QuestionTag {
  questionId String   @db.Uuid @map("question_id")
  tagId      String   @db.Uuid @map("tag_id")
  taggedBy   String?  @db.Uuid @map("tagged_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Restrict)

  @@id([questionId, tagId])
  @@index([tagId])
  @@map("question_tags")
}

/// Inter-question relationship graph (related, prereq, recommended_next).
model QuestionRelated {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromQuestionId String               @db.Uuid @map("from_question_id")
  toQuestionId   String               @db.Uuid @map("to_question_id")
  relationType   QuestionRelationType @map("relation_type")
  relationNote   String?              @map("relation_note")
  weight         Decimal              @default(1.00) @db.Decimal(3, 2)
  createdBy      String?              @db.Uuid @map("created_by")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz

  fromQuestion Question @relation("RelatedFrom", fields: [fromQuestionId], references: [id], onDelete: Cascade)
  toQuestion   Question @relation("RelatedTo", fields: [toQuestionId], references: [id], onDelete: Cascade)

  @@unique([fromQuestionId, toQuestionId])
  @@index([fromQuestionId, relationType])
  @@index([toQuestionId])
  @@map("question_related")
}

// ============================================================================
// MODULE 9: SUBSCRIPTION & BILLING (Sprint 2.5)
// ============================================================================

/// Billing cadence for a subscription plan.
enum PlanInterval {
  free
  monthly
  quarterly
  annual
  lifetime

  @@map("plan_interval")
}

/// Lifecycle state of a user's subscription.
enum SubscriptionStatus {
  trialing
  active
  past_due
  grace
  canceled
  expired

  @@map("subscription_status")
}

/// Lifecycle state of a payment attempt.
enum PaymentStatus {
  pending
  processing
  succeeded
  failed
  refunded
  canceled

  @@map("payment_status")
}

/// Supported payment providers (provider abstraction).
enum PaymentProviderType {
  paymongo
  xendit
  stripe
  mock

  @@map("payment_provider_type")
}

/// Supported payment methods (Philippine + international).
enum PaymentMethodType {
  gcash
  maya
  online_banking
  qrph
  credit_card
  debit_card

  @@map("payment_method_type")
}

/// Invoice lifecycle state.
enum InvoiceStatus {
  draft
  issued
  paid
  void

  @@map("invoice_status")
}

/// Webhook processing state (idempotency + replay protection).
enum WebhookStatus {
  received
  processed
  duplicate
  failed
  invalid_signature

  @@map("webhook_status")
}

/// Purchasable subscription plans. Maps tier + interval + price.
model SubscriptionPlan {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String       @db.VarChar(120)
  slug          String       @unique @db.VarChar(60)
  tier          SubscriptionTier
  interval      PlanInterval
  /// Price in the smallest currency unit (centavos for PHP). 0 for free.
  priceMinor    Int          @map("price_minor")
  currency      String       @default("PHP") @db.Char(3)
  /// Duration in days. Null for lifetime/free.
  durationDays  Int?         @map("duration_days")
  trialDays     Int          @default(0) @map("trial_days")
  features      Json         @default("[]")
  isActive      Boolean      @default(true) @map("is_active")
  sortOrder     Int          @default(0) @map("sort_order") @db.SmallInt
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz

  subscriptions Subscription[]

  @@index([tier])
  @@index([interval])
  @@index([isActive])
  @@map("subscription_plans")
}

/// A user's subscription to a plan. One active subscription per user enforced
/// in application logic; history is retained (multiple rows over time).
model Subscription {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @db.Uuid @map("user_id")
  planId            String             @db.Uuid @map("plan_id")
  status            SubscriptionStatus @default(trialing)
  /// Current paid period boundaries.
  currentPeriodStart DateTime?         @map("current_period_start") @db.Timestamptz
  currentPeriodEnd   DateTime?         @map("current_period_end") @db.Timestamptz
  trialEndsAt       DateTime?          @map("trial_ends_at") @db.Timestamptz
  /// When grace period (post past_due) ends; after this → expired.
  graceEndsAt       DateTime?          @map("grace_ends_at") @db.Timestamptz
  canceledAt        DateTime?          @map("canceled_at") @db.Timestamptz
  /// If true, do not auto-renew at period end.
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  autoRenew         Boolean            @default(true) @map("auto_renew")
  /// Provider-side subscription/customer identifiers (nullable for one-off).
  providerType      PaymentProviderType? @map("provider_type")
  providerRef       String?            @map("provider_ref")
  version           Int                @default(0)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]
  invoices Invoice[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([userId, status])
  @@map("subscriptions")
}

/// A payment attempt against a subscription (or standalone purchase).
model Payment {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String              @db.Uuid @map("user_id")
  subscriptionId  String?             @db.Uuid @map("subscription_id")
  amountMinor     Int                 @map("amount_minor")
  currency        String              @default("PHP") @db.Char(3)
  status          PaymentStatus       @default(pending)
  providerType    PaymentProviderType @map("provider_type")
  methodType      PaymentMethodType?  @map("method_type")
  /// Provider-side payment intent / charge id.
  providerRef     String?             @map("provider_ref")
  /// Client-supplied idempotency key — guarantees at-most-once creation.
  idempotencyKey  String?             @unique @db.VarChar(120) @map("idempotency_key")
  /// Checkout URL returned by the provider for redirect-based methods.
  checkoutUrl     String?             @map("checkout_url")
  failureReason   String?             @map("failure_reason")
  paidAt          DateTime?           @map("paid_at") @db.Timestamptz
  refundedAt      DateTime?           @map("refunded_at") @db.Timestamptz
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice      Invoice?
  webhooks     PaymentWebhook[]
  logs         PaymentLog[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([providerRef])
  @@index([createdAt])
  @@map("payments")
}

/// An invoice issued for a payment. Immutable once issued.
model Invoice {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String        @db.Uuid @map("user_id")
  subscriptionId String?       @db.Uuid @map("subscription_id")
  paymentId      String?       @unique @db.Uuid @map("payment_id")
  /// Human-readable invoice number, e.g. INV-2026-000123.
  number         String        @unique @db.VarChar(40)
  status         InvoiceStatus @default(draft)
  subtotalMinor  Int           @map("subtotal_minor")
  taxMinor       Int           @default(0) @map("tax_minor")
  totalMinor     Int           @map("total_minor")
  currency       String        @default("PHP") @db.Char(3)
  /// Line items snapshot (plan name, price, period).
  lineItems      Json          @default("[]")
  /// Receipt URL (PDF) once generated.
  receiptUrl     String?       @map("receipt_url")
  issuedAt       DateTime?     @map("issued_at") @db.Timestamptz
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([number])
  @@map("invoices")
}

/// Raw inbound provider webhooks — idempotency + replay protection.
model PaymentWebhook {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerType  PaymentProviderType @map("provider_type")
  /// Provider's unique event id — unique constraint enforces idempotency.
  eventId       String              @db.VarChar(200) @map("event_id")
  eventType     String              @db.VarChar(100) @map("event_type")
  paymentId     String?             @db.Uuid @map("payment_id")
  status        WebhookStatus       @default(received)
  /// Whether the HMAC signature verified.
  signatureValid Boolean            @default(false) @map("signature_valid")
  payload       Json
  error         String?
  receivedAt    DateTime            @default(now()) @map("received_at") @db.Timestamptz
  processedAt   DateTime?           @map("processed_at") @db.Timestamptz

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([providerType, eventId])
  @@index([status])
  @@index([eventType])
  @@index([receivedAt])
  @@map("payment_webhooks")
}

/// Append-only audit log of every payment state transition.
model PaymentLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentId   String   @db.Uuid @map("payment_id")
  action      String   @db.VarChar(80)
  fromStatus  String?  @db.VarChar(40) @map("from_status")
  toStatus    String?  @db.VarChar(40) @map("to_status")
  actorId     String?  @db.Uuid @map("actor_id")
  detail      Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([createdAt])
  @@map("payment_logs")
}

// ============================================================================
// MODULE 10: CONTENT KNOWLEDGE BASE (Sprint 2.8)
// ============================================================================
// The authoritative Content Knowledge Base. Ingests the official enterprise
// documentation (Books 1–15) as versioned KnowledgeDocuments, and exposes the
// structured governing entities — Learning Objectives, Blueprints, and
// Misconceptions — that every future question, explanation, diagram, and AI
// response must validate against. Formulas reuse the existing FormulaLibrary
// model (Module 5); this module adds the LO/Blueprint/Misconception spine and
// the cross-reference dependency graph. All additive; no existing model altered.

/// Lifecycle status shared by knowledge-base entities.
enum KnowledgeStatus {
  draft
  in_review
  approved
  published
  deprecated
  archived

  @@map("knowledge_status")
}

/// The category of an ingested enterprise document (Books 1–15).
enum KnowledgeDocumentType {
  authoring_bible
  knowledge_map
  question_writing_standards
  formula_library
  engineering_codes
  question_templates
  distractor_design
  explanation_standards
  psychometric_standards
  ai_content_generation
  learning_objectives
  question_blueprints
  misconceptions
  diagram_standards
  editorial_style

  @@map("knowledge_document_type")
}

/// Bloom's taxonomy cognitive level (mirrors BloomLevel; kept local so LO
/// records are self-describing without a hard FK into the question module).
enum LearningObjectiveStatus {
  draft
  in_review
  approved
  published
  deprecated
  archived

  @@map("learning_objective_status")
}

/// The kind of edge in the knowledge dependency graph.
enum CrossReferenceType {
  lo_to_formula
  lo_to_blueprint
  lo_to_misconception
  blueprint_to_lo
  blueprint_to_formula
  misconception_to_lo
  formula_to_lo
  document_to_entity
  lo_prerequisite

  @@map("cross_reference_type")
}

/// An ingested official enterprise document (one of Books 1–15). The latest
/// published version is the authoritative specification for its domain.
model KnowledgeDocument {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookNumber    Int                   @map("book_number") @db.SmallInt
  documentType  KnowledgeDocumentType @map("document_type")
  title         String                @db.VarChar(300)
  slug          String                @unique @db.VarChar(160)
  description   String?
  status        KnowledgeStatus       @default(draft)
  currentVersion Int                  @default(1) @map("current_version") @db.SmallInt
  latestSemver  String                @default("1.0.0") @map("latest_semver") @db.VarChar(20)
  sourceFilename String?              @map("source_filename")
  ownerTeam     String?               @map("owner_team") @db.VarChar(120)
  createdBy     String?               @db.Uuid @map("created_by")
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?             @map("deleted_at") @db.Timestamptz

  creator  User?                       @relation("KnowledgeDocCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  versions KnowledgeDocumentVersion[]
  sections KnowledgeSection[]

  @@unique([bookNumber])
  @@index([documentType])
  @@index([status])
  @@map("knowledge_documents")
}

/// An immutable snapshot of a KnowledgeDocument at a specific version. Holds the
/// full extracted text + a content checksum so re-ingestion is idempotent and
/// auditable.
model KnowledgeDocumentVersion {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId    String          @db.Uuid @map("document_id")
  versionNumber Int             @map("version_number") @db.SmallInt
  semver        String          @db.VarChar(20)
  status        KnowledgeStatus @default(draft)
  contentText   String          @map("content_text")
  contentChecksum String        @map("content_checksum") @db.VarChar(64)
  sectionCount  Int             @default(0) @map("section_count") @db.SmallInt
  wordCount     Int             @default(0) @map("word_count")
  changeSummary String?         @map("change_summary")
  ingestedBy    String?         @db.Uuid @map("ingested_by")
  isCurrent     Boolean         @default(false) @map("is_current")
  publishedAt   DateTime?       @map("published_at") @db.Timestamptz
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ingester User?             @relation("KnowledgeDocIngester", fields: [ingestedBy], references: [id], onDelete: SetNull)

  @@unique([documentId, versionNumber])
  @@index([documentId, isCurrent])
  @@index([contentChecksum])
  @@map("knowledge_document_versions")
}

/// A parsed section (chapter/heading) of a knowledge document, used for the
/// full-text index and for anchoring cross-references to a precise location.
model KnowledgeSection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId  String   @db.Uuid @map("document_id")
  anchor      String   @db.VarChar(120)
  heading     String   @db.VarChar(400)
  level       Int      @default(1) @db.SmallInt
  orderIndex  Int      @map("order_index")
  bodyText    String   @map("body_text")
  wordCount   Int      @default(0) @map("word_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, anchor])
  @@index([documentId, orderIndex])
  @@map("knowledge_sections")
}

/// A Learning Objective — the educational spine. Public ID format:
/// LO-<Subject>-<Topic>-<Subtopic>-<Number> (e.g. LO-STR-001-003-001).
model LearningObjective {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId        String                  @unique @db.VarChar(40) @map("public_id")
  subjectCode     String                  @db.VarChar(3) @map("subject_code")
  topicCode       String                  @db.VarChar(3) @map("topic_code")
  subtopicCode    String                  @db.VarChar(3) @map("subtopic_code")
  sequenceNumber  Int                     @map("sequence_number") @db.SmallInt
  subjectId       String?                 @db.Uuid @map("subject_id")
  statement       String
  bloomLevel      String                  @default("apply") @db.VarChar(20) @map("bloom_level")
  measurable      Boolean                 @default(true)
  status          LearningObjectiveStatus @default(draft)
  currentVersion  Int                     @default(1) @map("current_version") @db.SmallInt
  semver          String                  @default("1.0.0") @db.VarChar(20)
  keywords        String[]
  sourceDocumentId String?                @db.Uuid @map("source_document_id")
  createdBy       String?                 @db.Uuid @map("created_by")
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?               @map("deleted_at") @db.Timestamptz

  subject  Subject?                   @relation("SubjectLearningObjectives", fields: [subjectId], references: [id], onDelete: SetNull)
  creator  User?                      @relation("LoCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  versions LearningObjectiveVersion[]

  @@index([subjectCode, topicCode, subtopicCode])
  @@index([status])
  @@index([subjectId])
  @@map("learning_objectives")
}

/// Immutable version snapshot of a Learning Objective.
model LearningObjectiveVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objectiveId   String   @db.Uuid @map("objective_id")
  versionNumber Int      @map("version_number") @db.SmallInt
  semver        String   @db.VarChar(20)
  snapshot      Json
  changeSummary String?  @map("change_summary")
  changedBy     String?  @db.Uuid @map("changed_by")
  isCurrent     Boolean  @default(false) @map("is_current")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  objective LearningObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@unique([objectiveId, versionNumber])
  @@index([objectiveId, isCurrent])
  @@map("learning_objective_versions")
}

/// A Question Blueprint. Public ID format:
/// BP-<Subject>-<Topic>-<Subtopic>-<BlueprintType>-<Number>.
model QuestionBlueprint {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId           String          @unique @db.VarChar(50) @map("public_id")
  subjectCode        String          @db.VarChar(3) @map("subject_code")
  topicCode          String          @db.VarChar(3) @map("topic_code")
  subtopicCode       String          @db.VarChar(3) @map("subtopic_code")
  blueprintType      String          @db.VarChar(3) @map("blueprint_type")
  sequenceNumber     Int             @map("sequence_number") @db.SmallInt
  name               String          @db.VarChar(300)
  description        String?
  primaryObjectiveId String?         @db.Uuid @map("primary_objective_id")
  structure          Json
  difficultyBand     String?         @db.VarChar(20) @map("difficulty_band")
  status             KnowledgeStatus @default(draft)
  currentVersion     Int             @default(1) @map("current_version") @db.SmallInt
  semver             String          @default("1.0.0") @db.VarChar(20)
  sourceDocumentId   String?         @db.Uuid @map("source_document_id")
  createdBy          String?         @db.Uuid @map("created_by")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?       @map("deleted_at") @db.Timestamptz

  creator User? @relation("BlueprintCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([subjectCode, topicCode, subtopicCode])
  @@index([blueprintType])
  @@index([status])
  @@map("question_blueprints")
}

/// A Misconception. Public ID format:
/// MC-<Subject>-<Topic>-<Subtopic>-<Category>-<Number>.
model Misconception {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId           String          @unique @db.VarChar(50) @map("public_id")
  subjectCode        String          @db.VarChar(3) @map("subject_code")
  topicCode          String          @db.VarChar(3) @map("topic_code")
  subtopicCode       String          @db.VarChar(3) @map("subtopic_code")
  category           String          @db.VarChar(3)
  sequenceNumber     Int             @map("sequence_number") @db.SmallInt
  title              String          @db.VarChar(300)
  description        String
  whyItHappens       String?         @map("why_it_happens")
  correction         String?
  primaryObjectiveId String?         @db.Uuid @map("primary_objective_id")
  status             KnowledgeStatus @default(draft)
  currentVersion     Int             @default(1) @map("current_version") @db.SmallInt
  semver             String          @default("1.0.0") @db.VarChar(20)
  sourceDocumentId   String?         @db.Uuid @map("source_document_id")
  createdBy          String?         @db.Uuid @map("created_by")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?       @map("deleted_at") @db.Timestamptz

  creator User? @relation("MisconceptionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([subjectCode, topicCode, subtopicCode])
  @@index([category])
  @@index([status])
  @@map("misconceptions")
}

/// An edge in the knowledge dependency graph. Connects two knowledge entities
/// (referenced by their UUIDs + a denormalized public ID for fast traversal)
/// so the cross-reference and dependency-graph engines can resolve relationships
/// without N+1 lookups.
model KnowledgeCrossReference {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceType CrossReferenceType @map("reference_type")
  fromType     String             @db.VarChar(30) @map("from_type")
  fromId       String             @db.Uuid @map("from_id")
  fromPublicId String?            @db.VarChar(50) @map("from_public_id")
  toType       String             @db.VarChar(30) @map("to_type")
  toId         String             @db.Uuid @map("to_id")
  toPublicId   String?            @db.VarChar(50) @map("to_public_id")
  weight       Int                @default(1) @db.SmallInt
  note         String?
  createdBy    String?            @db.Uuid @map("created_by")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz

  @@unique([fromType, fromId, toType, toId, referenceType])
  @@index([fromType, fromId])
  @@index([toType, toId])
  @@index([referenceType])
  @@map("knowledge_cross_references")
}

// ============================================================================
// MODULE 11: AI CONTENT GENERATION ENGINE (Sprint 2.9)
// ============================================================================
// The enterprise AI Content Generation Engine. Generates questions, variants,
// explanations, solution steps, and distractors grounded EXCLUSIVELY in the
// Sprint 2.8 Knowledge Base (Learning Objectives, Blueprints, Formulas,
// Misconceptions, Editorial Standards). Every generation is recorded, every
// output runs the validation pipeline, and only validated drafts are handed to
// the CMS. All additive; no existing model altered.

/// Lifecycle of a single generation request.
enum GenerationStatus {
  pending
  generating
  validating
  validated
  rejected
  promoted    // accepted into the Question Bank as a draft
  failed

  @@map("generation_status")
}

/// What the engine was asked to produce.
enum GenerationKind {
  question_from_lo
  question_from_blueprint
  numerical_variant
  conceptual_variant
  explanation
  solution_steps
  distractors

  @@map("generation_kind")
}

/// Outcome of the validation pipeline for a generated artifact.
enum GenerationValidationOutcome {
  passed
  passed_with_warnings
  failed

  @@map("generation_validation_outcome")
}

/// A single AI generation request + its produced artifact. The authoritative
/// record of "what was asked, what was produced, and whether it passed."
model AiGenerationRequest {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind              GenerationKind
  status            GenerationStatus @default(pending)
  // Grounding references into the Knowledge Base (public IDs).
  learningObjectiveId String?        @db.VarChar(40) @map("learning_objective_id")
  blueprintId       String?          @db.VarChar(50) @map("blueprint_id")
  subjectCode       String?          @db.VarChar(3) @map("subject_code")
  topicCode         String?          @db.VarChar(3) @map("topic_code")
  difficultyBand    String?          @db.VarChar(20) @map("difficulty_band")
  // Inputs and outputs.
  parameters        Json             // request parameters (seed, variant options, count)
  prompt            String?          // the assembled prompt (audit)
  output            Json?            // the produced artifact(s)
  validationOutcome GenerationValidationOutcome? @map("validation_outcome")
  validationReport  Json?            @map("validation_report")
  promotedQuestionId String?         @db.Uuid @map("promoted_question_id")
  providerName      String           @default("deterministic") @db.VarChar(40) @map("provider_name")
  model             String?          @db.VarChar(80)
  seed              String?          @db.VarChar(64)
  contentHash       String?          @db.VarChar(64) @map("content_hash")
  errorMessage      String?          @map("error_message")
  requestedBy       String?          @db.Uuid @map("requested_by")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  completedAt       DateTime?        @map("completed_at") @db.Timestamptz

  requester  User?                  @relation("AiGenerationRequester", fields: [requestedBy], references: [id], onDelete: SetNull)
  auditLogs  AiGenerationAuditLog[]
  variants   AiGeneratedVariant[]

  @@index([status])
  @@index([kind])
  @@index([learningObjectiveId])
  @@index([requestedBy])
  @@index([contentHash])
  @@map("ai_generation_requests")
}

/// A produced variant belonging to a generation request (numerical/conceptual
/// variants share a parent request). Holds the question draft payload.
model AiGeneratedVariant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId     String   @db.Uuid @map("request_id")
  variantIndex  Int      @map("variant_index") @db.SmallInt
  variantType   String   @db.VarChar(20) @map("variant_type") // numerical | conceptual | base
  payload       Json     // the draft question (stem, choices, correct, explanation, refs)
  contentHash   String   @db.VarChar(64) @map("content_hash")
  isDuplicate   Boolean  @default(false) @map("is_duplicate")
  validationOutcome GenerationValidationOutcome? @map("validation_outcome")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  request AiGenerationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, variantIndex])
  @@index([contentHash])
  @@map("ai_generated_variants")
}

/// Append-only audit log of every pipeline stage for a generation request.
model AiGenerationAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId  String   @db.Uuid @map("request_id")
  stage      String   @db.VarChar(40)  // prompt_built | generated | validated | promoted | rejected
  status     String   @db.VarChar(20)
  detail     Json?
  message    String?
  actorId    String?  @db.Uuid @map("actor_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  request AiGenerationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([stage])
  @@map("ai_generation_audit_logs")
}

// ============================================================================
// MODULE 12: STUDENT LEARNING PLATFORM (Sprint 3.1)
// ============================================================================
// The student-facing learning platform. All models are owned by a user
// (ownership-scoped) and additive. Covers practice attempts & sessions,
// engagement (bookmarks/favorites/recently-viewed), progress & mastery,
// study planning, gamification (XP/levels/achievements), and knowledge-gap /
// learning-path generation. No existing model is altered.

enum AttemptOutcome {
  correct
  incorrect
  skipped

  @@map("attempt_outcome")
}

enum PracticeSessionMode {
  subject
  topic
  learning_objective
  blueprint
  difficulty
  recommended
  mixed

  @@map("practice_session_mode")
}

enum PracticeSessionStatus {
  active
  completed
  abandoned

  @@map("practice_session_status")
}

enum StudyGoalPeriod {
  daily
  weekly
  monthly

  @@map("study_goal_period")
}

enum StudyTaskStatus {
  pending
  in_progress
  completed
  skipped

  @@map("study_task_status")
}

enum MasteryTier {
  novice
  developing
  proficient
  advanced
  mastered

  @@map("mastery_tier")
}

enum AchievementKind {
  streak
  volume
  accuracy
  mastery
  milestone
  speed

  @@map("achievement_kind")
}

enum KnowledgeGapSeverity {
  minor
  moderate
  critical

  @@map("knowledge_gap_severity")
}

/// Every answer a student submits. The atomic unit of progress & analytics.
model QuestionAttempt {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @db.Uuid @map("user_id")
  questionId      String         @db.Uuid @map("question_id")
  sessionId       String?        @db.Uuid @map("session_id")
  subjectId       String         @db.Uuid @map("subject_id")
  topicId         String?        @db.Uuid @map("topic_id")
  subtopicId      String?        @db.Uuid @map("subtopic_id")
  difficultyLevelId String?      @db.Uuid @map("difficulty_level_id")
  selectedChoice  String?        @db.VarChar(2) @map("selected_choice")
  outcome         AttemptOutcome
  isCorrect       Boolean        @map("is_correct")
  timeSpentSec    Int            @default(0) @map("time_spent_sec")
  bloomLevel      String?        @db.VarChar(20) @map("bloom_level")
  attemptedAt     DateTime       @default(now()) @map("attempted_at") @db.Timestamptz

  user     User     @relation("UserQuestionAttempts", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation("QuestionAttempts", fields: [questionId], references: [id], onDelete: Cascade)
  session  PracticeSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, attemptedAt])
  @@index([userId, subjectId])
  @@index([userId, topicId])
  @@index([questionId])
  @@index([sessionId])
  @@map("question_attempts")
}

/// A practice session groups attempts by a chosen mode (subject/topic/etc).
model PracticeSession {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String                @db.Uuid @map("user_id")
  mode          PracticeSessionMode
  status        PracticeSessionStatus @default(active)
  // Mode targets (only the relevant one is set).
  subjectId     String?               @db.Uuid @map("subject_id")
  topicId       String?               @db.Uuid @map("topic_id")
  subtopicId    String?               @db.Uuid @map("subtopic_id")
  learningObjectiveId String?         @db.VarChar(40) @map("learning_objective_id")
  blueprintId   String?               @db.VarChar(50) @map("blueprint_id")
  difficultyLevelId String?           @db.Uuid @map("difficulty_level_id")
  targetCount   Int                   @default(10) @map("target_count")
  answeredCount Int                   @default(0) @map("answered_count")
  correctCount  Int                   @default(0) @map("correct_count")
  totalTimeSec  Int                   @default(0) @map("total_time_sec")
  startedAt     DateTime              @default(now()) @map("started_at") @db.Timestamptz
  completedAt   DateTime?             @map("completed_at") @db.Timestamptz

  user     User              @relation("UserPracticeSessions", fields: [userId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]

  @@index([userId, status])
  @@index([userId, startedAt])
  @@map("practice_sessions")
}

/// A bookmarked question (saved to revisit). Unique per user+question.
model Bookmark {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  questionId String   @db.Uuid @map("question_id")
  note       String?  @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation("QuestionBookmarks", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, createdAt])
  @@map("bookmarks")
}

/// A favorited question (distinct from bookmark: a "best of" list).
model Favorite {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  questionId String   @db.Uuid @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation("QuestionFavorites", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, createdAt])
  @@map("favorites")
}

/// Recently viewed questions (capped ring per user, newest first).
model RecentlyViewed {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  questionId String   @db.Uuid @map("question_id")
  viewedAt   DateTime @default(now()) @map("viewed_at") @db.Timestamptz

  user     User     @relation("UserRecentlyViewed", fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation("QuestionRecentlyViewed", fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, viewedAt])
  @@map("recently_viewed")
}

/// Per-user mastery of a topic (rolling accuracy → tier). One row per user+topic.
model TopicMastery {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @db.Uuid @map("user_id")
  subjectId     String      @db.Uuid @map("subject_id")
  topicId       String      @db.Uuid @map("topic_id")
  attempts      Int         @default(0)
  correct       Int         @default(0)
  accuracy      Float       @default(0)
  avgTimeSec    Float       @default(0) @map("avg_time_sec")
  masteryScore  Float       @default(0) @map("mastery_score")
  tier          MasteryTier @default(novice)
  lastPracticedAt DateTime? @map("last_practiced_at") @db.Timestamptz
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation("UserTopicMastery", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, subjectId])
  @@index([userId, masteryScore])
  @@map("topic_mastery")
}

/// A study goal for a period (e.g., 20 questions/day). Progress tracked daily.
model StudyGoal {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid @map("user_id")
  period      StudyGoalPeriod
  targetQuestions Int         @map("target_questions")
  targetMinutes   Int?        @map("target_minutes")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation("UserStudyGoals", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, isActive])
  @@map("study_goals")
}

/// Daily study streak ledger. One row per user+date with that day's activity.
model StudyStreakDay {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  date          DateTime @db.Date
  questionsAnswered Int  @default(0) @map("questions_answered")
  minutesStudied Int     @default(0) @map("minutes_studied")
  goalMet       Boolean  @default(false) @map("goal_met")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation("UserStreakDays", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("study_streak_days")
}

/// A study plan (calendar of tasks toward the board exam).
model StudyPlan {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid @map("user_id")
  title       String          @db.VarChar(200)
  description String?
  startDate   DateTime        @db.Date @map("start_date")
  endDate     DateTime        @db.Date @map("end_date")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user  User            @relation("UserStudyPlans", fields: [userId], references: [id], onDelete: Cascade)
  tasks StudyPlanTask[]

  @@index([userId, isActive])
  @@map("study_plans")
}

/// A scheduled task within a study plan.
model StudyPlanTask {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId      String          @db.Uuid @map("plan_id")
  userId      String          @db.Uuid @map("user_id")
  title       String          @db.VarChar(200)
  scheduledDate DateTime      @db.Date @map("scheduled_date")
  subjectId   String?         @db.Uuid @map("subject_id")
  topicId     String?         @db.Uuid @map("topic_id")
  targetQuestions Int         @default(10) @map("target_questions")
  status      StudyTaskStatus @default(pending)
  completedAt DateTime?       @map("completed_at") @db.Timestamptz
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user User      @relation("UserStudyTasks", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledDate])
  @@index([planId])
  @@index([userId, status])
  @@map("study_plan_tasks")
}

/// Catalog of achievements (definitions). Seeded; shared across all students.
model Achievement {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String          @unique @db.VarChar(50)
  name        String          @db.VarChar(120)
  description String
  kind        AchievementKind
  threshold   Int             @default(0)
  xpReward    Int             @default(0) @map("xp_reward")
  icon        String?         @db.VarChar(80)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  awards StudentAchievement[]

  @@index([kind])
  @@map("achievements")
}

/// An achievement earned by a student. Unique per user+achievement.
model StudentAchievement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid @map("user_id")
  achievementId String   @db.Uuid @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at") @db.Timestamptz

  user        User        @relation("UserAchievements", fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, earnedAt])
  @@map("student_achievements")
}

/// XP and level for a student (gamification). One row per user.
model StudentXp {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @unique @db.Uuid @map("user_id")
  totalXp       Int      @default(0) @map("total_xp")
  level         Int      @default(1)
  currentStreak Int      @default(0) @map("current_streak")
  longestStreak Int      @default(0) @map("longest_streak")
  lastActivityDate DateTime? @db.Date @map("last_activity_date")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation("UserXp", fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalXp])
  @@map("student_xp")
}

/// A detected knowledge gap (weak topic) for a student.
model KnowledgeGap {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String               @db.Uuid @map("user_id")
  subjectId   String               @db.Uuid @map("subject_id")
  topicId     String               @db.Uuid @map("topic_id")
  severity    KnowledgeGapSeverity
  accuracy    Float                @default(0)
  attempts    Int                  @default(0)
  recommendation String?
  resolvedAt  DateTime?            @map("resolved_at") @db.Timestamptz
  detectedAt  DateTime             @default(now()) @map("detected_at") @db.Timestamptz

  user User @relation("UserKnowledgeGaps", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, severity])
  @@map("knowledge_gaps")
}

/// A generated learning path (ordered steps) toward closing gaps / mastery.
model LearningPath {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  title       String   @db.VarChar(200)
  steps       Json     // ordered [{ topicId, reason, targetAccuracy, order }]
  isActive    Boolean  @default(true) @map("is_active")
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz

  user User @relation("UserLearningPaths", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("learning_paths")
}

// ============================================================================
// MODULE 13: MOCK EXAMINATION ENGINE (Sprint 3.2)
// ============================================================================
// Enterprise mock-exam engine. Additive and ownership-scoped. Covers exam
// templates (composition blueprints), exam attempts (sessions) with timing /
// autosave / resume / auto-submit, per-question snapshots (randomized question &
// choice order), scoring with detailed breakdowns (subject/topic/LO/blueprint),
// and certificate- / leaderboard-ready results. No existing model is altered.

enum ExamKind {
  full_board          // full CE board simulation across all subjects
  subject             // single-subject mock
  custom              // user-defined composition
  adaptive            // difficulty adapts to performance
  ai_generated        // questions produced by the AI engine

  @@map("exam_kind")
}

enum ExamStatus {
  created
  in_progress
  paused
  submitted
  expired
  abandoned

  @@map("exam_status")
}

enum ExamResultStatus {
  pass
  fail
  pending

  @@map("exam_result_status")
}

enum ExamQuestionState {
  unanswered
  answered
  flagged
  skipped

  @@map("exam_question_state")
}

/// A reusable exam template: how to compose an exam (counts, weighting, timing).
model ExamTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(160)
  description     String?
  kind            ExamKind
  totalQuestions  Int      @map("total_questions")
  durationMinutes Int      @map("duration_minutes")
  passingScore    Float    @default(70) @map("passing_score") // percentage
  randomizeQuestions Boolean @default(true) @map("randomize_questions")
  randomizeChoices Boolean  @default(true) @map("randomize_choices")
  // Composition: ordered [{ subjectId, count, difficultyLevelId? , weightPercent? }]
  composition     Json
  isActive        Boolean  @default(true) @map("is_active")
  createdBy       String?  @db.Uuid @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  creator User?      @relation("ExamTemplateCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  exams   MockExam[]

  @@index([kind, isActive])
  @@map("exam_templates")
}

/// A single exam attempt by a student. The session of record.
model MockExam {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String     @db.Uuid @map("user_id")
  templateId      String?    @db.Uuid @map("template_id")
  kind            ExamKind
  title           String     @db.VarChar(160)
  status          ExamStatus @default(created)
  totalQuestions  Int        @map("total_questions")
  durationMinutes Int        @map("duration_minutes")
  passingScore    Float      @map("passing_score")
  randomizeChoices Boolean   @default(true) @map("randomize_choices")
  // Timing
  startedAt       DateTime?  @map("started_at") @db.Timestamptz
  expiresAt       DateTime?  @map("expires_at") @db.Timestamptz
  submittedAt     DateTime?  @map("submitted_at") @db.Timestamptz
  pausedAt        DateTime?  @map("paused_at") @db.Timestamptz
  elapsedSeconds  Int        @default(0) @map("elapsed_seconds")
  // Progress (denormalized for resume/autosave)
  answeredCount   Int        @default(0) @map("answered_count")
  lastActivityAt  DateTime?  @map("last_activity_at") @db.Timestamptz
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user      User           @relation("UserMockExams", fields: [userId], references: [id], onDelete: Cascade)
  template  ExamTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  questions ExamQuestion[]
  result    ExamResult?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@map("mock_exams")
}

/// A question placed in an exam, with its randomized position and choice order.
model ExamQuestion {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId        String            @db.Uuid @map("exam_id")
  questionId    String            @db.Uuid @map("question_id")
  userId        String            @db.Uuid @map("user_id")
  position      Int               // randomized order within the exam
  // Snapshot of taxonomy at exam-build time (decoupled from live edits).
  subjectId     String            @db.Uuid @map("subject_id")
  topicId       String?           @db.Uuid @map("topic_id")
  difficultyLevelId String?       @db.Uuid @map("difficulty_level_id")
  learningObjective String?       @db.VarChar(80) @map("learning_objective")
  // Randomized choice order: ['C','A','D','B'] mapping presented→original letters.
  choiceOrder   Json              @map("choice_order")
  correctChoice String            @db.Char(1) @map("correct_choice")
  state         ExamQuestionState @default(unanswered)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz

  exam     MockExam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question        @relation("QuestionExamQuestions", fields: [questionId], references: [id], onDelete: Cascade)
  answer   ExamAnswer?

  @@unique([examId, questionId])
  @@unique([examId, position])
  @@index([examId, position])
  @@index([userId])
  @@map("exam_questions")
}

/// A student's answer to an exam question (autosaved; gradeable on submit).
model ExamAnswer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examQuestionId String   @unique @db.Uuid @map("exam_question_id")
  examId         String   @db.Uuid @map("exam_id")
  userId         String   @db.Uuid @map("user_id")
  selectedChoice String?  @db.Char(1) @map("selected_choice") // original letter
  isCorrect      Boolean? @map("is_correct")                  // graded on submit
  isBookmarked   Boolean  @default(false) @map("is_bookmarked")
  timeSpentSec   Int      @default(0) @map("time_spent_sec")
  answeredAt     DateTime @default(now()) @map("answered_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  examQuestion ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@index([examId, userId])
  @@index([examId, isBookmarked])
  @@map("exam_answers")
}

/// The scored result of a submitted exam. Certificate-/leaderboard-ready.
model ExamResult {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId         String           @unique @db.Uuid @map("exam_id")
  userId         String           @db.Uuid @map("user_id")
  totalQuestions Int              @map("total_questions")
  answeredCount  Int              @map("answered_count")
  correctCount   Int              @map("correct_count")
  incorrectCount Int              @map("incorrect_count")
  skippedCount   Int              @map("skipped_count")
  scorePercent   Float            @map("score_percent")
  passingScore   Float            @map("passing_score")
  status         ExamResultStatus @default(pending)
  timeSpentSec   Int              @default(0) @map("time_spent_sec")
  // Certificate-ready: stable public id + verification hash (no PDF here).
  resultCode     String           @unique @db.VarChar(40) @map("result_code")
  // Leaderboard-ready: percentile filled by analytics.
  percentile     Float?
  computedAt     DateTime         @default(now()) @map("computed_at") @db.Timestamptz

  user          User                @relation("UserExamResults", fields: [userId], references: [id], onDelete: Cascade)
  exam          MockExam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectScores ExamSubjectScore[]
  topicScores   ExamTopicScore[]

  @@index([userId, computedAt])
  @@index([status, scorePercent])
  @@map("exam_results")
}

/// Per-subject score breakdown for a result.
model ExamSubjectScore {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId      String @db.Uuid @map("result_id")
  subjectId     String @db.Uuid @map("subject_id")
  total         Int
  correct       Int
  scorePercent  Float  @map("score_percent")
  weightPercent Float? @map("weight_percent")

  result ExamResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, subjectId])
  @@index([resultId])
  @@map("exam_subject_scores")
}

/// Per-topic score breakdown for a result (feeds weakness/strength analysis).
model ExamTopicScore {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId     String @db.Uuid @map("result_id")
  subjectId    String @db.Uuid @map("subject_id")
  topicId      String @db.Uuid @map("topic_id")
  total        Int
  correct      Int
  scorePercent Float  @map("score_percent")

  result ExamResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@unique([resultId, topicId])
  @@index([resultId])
  @@map("exam_topic_scores")
}

// ============================================================================
// MODULE 14: AI TUTOR & INTELLIGENT LEARNING ASSISTANT (Sprint 3.3)
// ============================================================================
// Conversational AI tutor grounded in the Knowledge Base and powered by the
// AI Generation Engine's provider seam. Additive and ownership-scoped. Covers
// multi-turn conversations with session memory, per-message citations (LO /
// formula / misconception / blueprint), and a coaching ledger that turns weak
// topics and exam mistakes into guidance. No existing model is altered.

enum TutorConversationStatus {
  active
  archived

  @@map("tutor_conversation_status")
}

enum TutorMessageRole {
  user
  assistant
  system

  @@map("tutor_message_role")
}

enum TutorIntent {
  ask_question        // free-form engineering question
  explain_concept     // explain a concept / topic
  explain_question    // explain a specific bank question
  step_solution       // step-by-step worked solution
  hint                // a graded hint (no full answer)
  formula_help        // formula lookup / usage
  coaching            // weak-topic / mistake coaching
  followup            // follow-up within a thread

  @@map("tutor_intent")
}

enum TutorCitationKind {
  learning_objective
  formula
  misconception
  blueprint
  knowledge_document
  question

  @@map("tutor_citation_kind")
}

enum CoachingTrigger {
  weak_topic
  knowledge_gap
  exam_mistake
  misconception
  streak_risk

  @@map("coaching_trigger")
}

/// A tutoring conversation (a thread). Owns session memory + a rolling summary.
model TutorConversation {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String                  @db.Uuid @map("user_id")
  title        String                  @db.VarChar(200)
  status       TutorConversationStatus @default(active)
  // Lightweight subject/topic focus (for grounding & filtering).
  subjectId    String?                 @db.Uuid @map("subject_id")
  topicId      String?                 @db.Uuid @map("topic_id")
  // Session memory: a rolling summary the tutor maintains across turns.
  memorySummary String?                @map("memory_summary")
  messageCount Int                     @default(0) @map("message_count")
  lastMessageAt DateTime?              @map("last_message_at") @db.Timestamptz
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     User            @relation("UserTutorConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages TutorMessage[]

  @@index([userId, status])
  @@index([userId, lastMessageAt])
  @@map("tutor_conversations")
}

/// A single message in a conversation (user or assistant), with grounding meta.
model TutorMessage {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String           @db.Uuid @map("conversation_id")
  userId         String           @db.Uuid @map("user_id")
  role           TutorMessageRole
  intent         TutorIntent?
  content        String
  // Grounding metadata for assistant messages.
  questionId     String?          @db.Uuid @map("question_id")
  groundedInKb   Boolean          @default(false) @map("grounded_in_kb")
  validatedOk    Boolean?         @map("validated_ok")
  // Provider attribution (deterministic now, LLM-ready).
  providerName   String?          @db.VarChar(60) @map("provider_name")
  tokensIn       Int?             @map("tokens_in")
  tokensOut      Int?             @map("tokens_out")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz

  conversation TutorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  citations    TutorCitation[]

  @@index([conversationId, createdAt])
  @@index([userId])
  @@map("tutor_messages")
}

/// A citation attached to an assistant message (Knowledge Base provenance).
model TutorCitation {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId   String            @db.Uuid @map("message_id")
  kind        TutorCitationKind
  refId       String            @map("ref_id")      // publicId or UUID of the cited entity
  label       String            @db.VarChar(300)
  snippet     String?
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz

  message TutorMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([kind, refId])
  @@map("tutor_citations")
}

/// A coaching note generated for a student (weak topic, gap, or exam mistake).
model TutorCoachingNote {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid @map("user_id")
  trigger     CoachingTrigger
  subjectId   String?         @db.Uuid @map("subject_id")
  topicId     String?         @db.Uuid @map("topic_id")
  title       String          @db.VarChar(200)
  message     String
  // Optional link to the source (an exam, a misconception, etc.).
  sourceType  String?         @db.VarChar(40) @map("source_type")
  sourceId    String?         @db.Uuid @map("source_id")
  priority    Int             @default(0)
  isRead      Boolean         @default(false) @map("is_read")
  isDismissed Boolean         @default(false) @map("is_dismissed")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz

  user User @relation("UserCoachingNotes", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, trigger])
  @@map("tutor_coaching_notes")
}
