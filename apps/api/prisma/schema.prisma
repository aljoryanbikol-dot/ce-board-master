/// Junction: question ↔ engineering code at section level.
model QuestionCodeReference {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId        String      @db.Uuid @map("question_id")
  engineeringCodeId String      @db.Uuid @map("engineering_code_id")
  sectionNumber     String?     @db.VarChar(30) @map("section_number")
  clauseTitle       String?     @db.VarChar(300) @map("clause_title")
