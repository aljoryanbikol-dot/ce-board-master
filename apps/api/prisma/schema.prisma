/// Immutable version history for every question edit.
model QuestionVersion {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId      String     @db.Uuid @map("question_id")
  versionNumber   Int        @map("version_number") @db.SmallInt
  contentSnapshot Json       @map("content_snapshot")
  changeSummary   String?    @map("change_summary")
  changeType      ChangeType @default(edit) @map("change_type")
  changedBy       String     @db.Uuid @map("changed_by")
  reviewedBy      String?    @db.Uuid @map("reviewed_by")
