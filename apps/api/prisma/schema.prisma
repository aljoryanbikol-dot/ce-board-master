  correctAttempts       BigInt   @default(0) @map("correct_attempts")
  accuracyRate          Decimal  @default(0) @map("accuracy_rate") @db.Decimal(5, 4)
  avgSolvingTimeSec     Decimal? @map("avg_solving_time_sec") @db.Decimal(8, 2)
  medianSolvingTimeSec  Decimal? @map("median_solving_time_sec") @db.Decimal(8, 2)
  skipRate              Decimal  @default(0) @map("skip_rate") @db.Decimal(5, 4)
  choiceARate           Decimal  @default(0) @map("choice_a_rate") @db.Decimal(5, 4)
  choiceBRate           Decimal  @default(0) @map("choice_b_rate") @db.Decimal(5, 4)
  choiceCRate           Decimal  @default(0) @map("choice_c_rate") @db.Decimal(5, 4)
  choiceDRate           Decimal  @default(0) @map("choice_d_rate") @db.Decimal(5, 4)
  difficultyIndex       Decimal? @map("difficulty_index") @db.Decimal(5, 4)
  discriminationIndex   Decimal? @map("discrimination_index") @db.Decimal(5, 4)
  qualityScore          Decimal? @map("quality_score") @db.Decimal(5, 2)
