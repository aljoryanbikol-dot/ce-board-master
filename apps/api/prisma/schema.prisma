  isCurrent       Boolean    @default(false) @map("is_current")
  publishedAt     DateTime?  @map("published_at") @db.Timestamptz
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  changedByUser  User @relation("VersionChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)
  reviewedByUser User? @relation("VersionReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([questionId, versionNumber])
  @@index([changedBy])
  @@index([questionId, createdAt])
  @@map("question_versions")
}

/// Immutable workflow event log: every status transition for a question.
model QuestionReviewWorkflow {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId    String         @db.Uuid @map("question_id")
  versionNumber Int?           @map("version_number") @db.SmallInt
  fromStatus    QuestionStatus? @map("from_status")
  toStatus      QuestionStatus  @map("to_status")
  actionType    ReviewAction    @map("action_type")
  actionBy      String          @db.Uuid @map("action_by")
  notes         String?
  occurredAt    DateTime        @default(now()) @map("occurred_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  actionByUser User @relation(fields: [actionBy], references: [id], onDelete: Restrict)

  @@index([questionId, occurredAt])
  @@index([actionBy, occurredAt])
  @@index([toStatus, occurredAt])
  @@map("question_review_workflow")
}

// ============================================================================
// MODULE 4B: ADMIN CMS LAYER (Sprint 2.7)
// ============================================================================
// Operational collaboration tables for the Admin CMS. These sit ON TOP of the
// Question Bank: editing locks, reviewer assignment, threaded review comments,
// and internal editorial notes. The question lifecycle itself remains owned by
// the Question Bank (Sprint 2.6); these tables add the human-coordination layer.

/// Pessimistic editing lock. At most one ACTIVE (released_at IS NULL, not
/// expired) lock per question, enforced by a partial unique index in the
/// migration. Prevents two editors clobbering each other in the CMS.
model QuestionLock {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId  String    @db.Uuid @map("question_id")
  lockedBy    String    @db.Uuid @map("locked_by")
  reason      String?
  acquiredAt  DateTime  @default(now()) @map("acquired_at") @db.Timestamptz
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  releasedAt  DateTime? @map("released_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  locker   User     @relation("QuestionLockHolder", fields: [lockedBy], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([lockedBy])
  @@index([expiresAt])
  @@map("question_locks")
}

/// Reviewer assignment for a question at a specific review stage. A question
/// may have at most one ACTIVE (completed_at IS NULL) assignment per stage,
/// enforced by a partial unique index in the migration.
model ReviewAssignment {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId   String       @db.Uuid @map("question_id")
  assigneeId   String       @db.Uuid @map("assignee_id")
  assignedBy   String       @db.Uuid @map("assigned_by")
  stage        ReviewStage  @map("stage")
  status       AssignmentStatus @default(pending) @map("status")
  dueAt        DateTime?    @map("due_at") @db.Timestamptz
  assignedAt   DateTime     @default(now()) @map("assigned_at") @db.Timestamptz
  completedAt  DateTime?    @map("completed_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assignee User     @relation("AssignmentAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  assigner User     @relation("AssignmentAssigner", fields: [assignedBy], references: [id], onDelete: Restrict)

  @@index([questionId, stage])
  @@index([assigneeId, status])
  @@index([status, dueAt])
  @@map("review_assignments")
}

/// Threaded review comment on a question, optionally scoped to a review stage
/// and optionally a reply to a parent comment. Resolvable for review tracking.
model ReviewComment {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId  String       @db.Uuid @map("question_id")
  authorId    String       @db.Uuid @map("author_id")
  parentId    String?      @db.Uuid @map("parent_id")
  stage       ReviewStage? @map("stage")
  body        String
  isResolved  Boolean      @default(false) @map("is_resolved")
  resolvedBy  String?      @db.Uuid @map("resolved_by")
  resolvedAt  DateTime?    @map("resolved_at") @db.Timestamptz
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  commenter  User            @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  resolver   User?           @relation("CommentResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)
  parent     ReviewComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ReviewComment[] @relation("CommentThread")

  @@index([questionId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("review_comments")
}

/// Internal editorial note attached to a question. Distinct from review
/// comments: notes are persistent editorial guidance (style, sourcing, PRC
/// alignment) rather than threaded review discussion.
model EditorialNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId  String   @db.Uuid @map("question_id")
  authorId    String   @db.Uuid @map("author_id")
  category    EditorialNoteCategory @default(general) @map("category")
  body        String
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  noter    User     @relation("EditorialNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([questionId, isPinned])
  @@index([authorId])
  @@map("editorial_notes")
}

