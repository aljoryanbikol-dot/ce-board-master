// ============================================================================
// CE Board Master — Prisma Database Schema
// Phase 2 Database Architecture — Approved 2026-06-25
//
// All tables follow the design principles in Database Design Specification:
// - UUID v7 primary keys (via gen_random_uuid() until pg_uuidv7 extension)
// - created_at / updated_at on every table (updated_at via trigger)
// - deleted_at for soft delete on business data tables
// - snake_case naming throughout
//
// PostgreSQL 16+ is the target database.
// PgBouncer sits between the application and RDS (transaction mode).
//
// IMPORTANT: Do NOT modify this schema without updating the Database Design
// Specification document. All changes require numbered migration files.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins", "omitApi"]
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserStatus {
  pending
  active
  suspended
  deactivated

  @@map("user_status")
}

enum OAuthProvider {
  google
  facebook
  apple

  @@map("oauth_provider")
}

enum MfaMethod {
  totp

  @@map("mfa_method")
}

enum AuthTokenType {
  refresh
  email_verify
  password_reset
  mfa_backup

  @@map("auth_token_type")
}

enum LoginFailReason {
  wrong_password
  unverified
  suspended
  mfa_failed
  account_locked

  @@map("login_fail_reason")
}

enum SubscriptionTier {
  free
  basic
  pro

  @@map("subscription_tier")
}

enum QuestionStatus {
  draft
  in_review
  approved
  published
  archived
  flagged

  @@map("question_status")
}

enum BloomLevel {
  remember
  understand
  apply
  analyze
  evaluate
  create

  @@map("bloom_level")
}

enum QuestionType {
  multiple_choice
  computation
  diagram_based

  @@map("question_type")
}

enum ImageType {
  figure
  diagram
  chart
  formula_image
  choice_image
  explanation_image

  @@map("image_type")
}

enum ImagePosition {
  stem
  choice_a
  choice_b
  choice_c
  choice_d
  explanation

  @@map("image_position")
}

enum ChangeType {
  create
  edit
  correction
  choice_update
  explanation_update
  metadata_update

  @@map("change_type")
}

// ── Admin CMS enums (Sprint 2.7) ──────────────────────────────────────────────

/// The four editorial review stages. Mirrors the application-level REVIEW_STAGES
/// from Sprint 2.6 (which layered stages under the in_review status); persisted
/// here so assignments and comments can be scoped to a specific stage.
enum ReviewStage {
  technical
  educational
  editorial
  qa

  @@map("review_stage")
}

/// Lifecycle of a reviewer assignment.
enum AssignmentStatus {
  pending
  accepted
  completed
  declined
  reassigned

  @@map("assignment_status")
}

/// Category of an internal editorial note.
enum EditorialNoteCategory {
  general
  style
  sourcing
  prc_alignment
  correction
  warning

  @@map("editorial_note_category")
}

enum ReviewAction {
  submit
  approve
  reject
  request_changes
  publish
  archive
  flag
  unflag

  @@map("review_action")
}

enum EngCodeType {
  structural
  geotechnical
  hydraulic
  transportation
  sanitary
  electrical
  general
  international

  @@map("eng_code_type")
}

enum CodeReqType {
  reference
  basis_of_design
  formula_source
  limit_value
  definition

  @@map("code_req_type")
}

enum TagCategory {
  general
  prc_exam
  difficulty
  topic_theme
  skill_type
  exam_year

  @@map("tag_category")
}

enum QuestionRelationType {
  related
  prerequisite
  recommended_next
  same_concept
  common_exam_pair

  @@map("question_relation_type")
}

// ============================================================================
// MODULE 1: USERS & AUTHENTICATION
// ============================================================================

/// Master identity record for every person in the system.
/// Holds authentication-critical data only. Extended profile in UserProfile.
model User {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String       @unique @db.VarChar(320)
  username      String?      @unique @db.VarChar(30)
  passwordHash  String?      @db.VarChar(255) @map("password_hash")
  roleId        String       @db.Uuid @map("role_id")
  status        UserStatus   @default(pending)
  isVerified    Boolean      @default(false) @map("is_verified")
  isActive      Boolean      @default(true) @map("is_active")
  lastLoginAt   DateTime?    @map("last_login_at") @db.Timestamptz
  lastLoginIp   String?      @map("last_login_ip")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz
  version       Int          @default(0)

  // Relations
  role                    Role                  @relation(fields: [roleId], references: [id], onDelete: Restrict)
  profile                 UserProfile?
  authTokens              UserAuthToken[]
  oauthAccounts           OauthAccount[]
  mfaConfig               MfaConfig?
  loginAttempts           LoginAttempt[]
  authoredQuestions       Question[]            @relation("QuestionAuthor")
  reviewedQuestions       Question[]            @relation("QuestionReviewer")
  publishedQuestions      Question[]            @relation("QuestionPublisher")
  questionVersions        QuestionVersion[]     @relation("VersionChangedBy")
  reviewedVersions        QuestionVersion[]     @relation("VersionReviewedBy")
  reviewWorkflowActions   QuestionReviewWorkflow[]
  uploadedImages          QuestionImage[]
  userRoles               UserRole[]
  subscriptions           Subscription[]
  payments                Payment[]
  invoices                Invoice[]
  questionLocks           QuestionLock[]        @relation("QuestionLockHolder")
  reviewAssignmentsGiven  ReviewAssignment[]    @relation("AssignmentAssigner")
  reviewAssignmentsGot    ReviewAssignment[]    @relation("AssignmentAssignee")
  reviewComments          ReviewComment[]       @relation("CommentAuthor")
  resolvedComments        ReviewComment[]       @relation("CommentResolver")
  editorialNotes          EditorialNote[]       @relation("EditorialNoteAuthor")
  knowledgeDocsCreated    KnowledgeDocument[]        @relation("KnowledgeDocCreator")
  knowledgeDocsIngested   KnowledgeDocumentVersion[] @relation("KnowledgeDocIngester")
  learningObjectivesCreated LearningObjective[]      @relation("LoCreator")
  blueprintsCreated       QuestionBlueprint[]        @relation("BlueprintCreator")
  misconceptionsCreated   Misconception[]            @relation("MisconceptionCreator")
  aiGenerationRequests    AiGenerationRequest[]      @relation("AiGenerationRequester")
  questionAttempts        QuestionAttempt[]          @relation("UserQuestionAttempts")
  practiceSessions        PracticeSession[]          @relation("UserPracticeSessions")
  bookmarks               Bookmark[]                 @relation("UserBookmarks")
  favorites               Favorite[]                 @relation("UserFavorites")
  recentlyViewed          RecentlyViewed[]           @relation("UserRecentlyViewed")
  topicMastery            TopicMastery[]             @relation("UserTopicMastery")
  studyGoals              StudyGoal[]                @relation("UserStudyGoals")
  streakDays              StudyStreakDay[]           @relation("UserStreakDays")
  studyPlans              StudyPlan[]                @relation("UserStudyPlans")
  studyTasks              StudyPlanTask[]            @relation("UserStudyTasks")
  achievements            StudentAchievement[]       @relation("UserAchievements")
  xp                      StudentXp?                 @relation("UserXp")
  knowledgeGaps           KnowledgeGap[]             @relation("UserKnowledgeGaps")
  learningPaths           LearningPath[]             @relation("UserLearningPaths")
  examTemplatesCreated    ExamTemplate[]             @relation("ExamTemplateCreator")
  mockExams               MockExam[]                 @relation("UserMockExams")
  examResults             ExamResult[]               @relation("UserExamResults")
  tutorConversations      TutorConversation[]        @relation("UserTutorConversations")
  coachingNotes           TutorCoachingNote[]        @relation("UserCoachingNotes")

  @@index([email])
  @@index([username])
  @@index([roleId])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

/// Extended profile data for each user (1:1 with User).
model UserProfile {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @unique @db.Uuid @map("user_id")
  firstName          String?   @db.VarChar(100) @map("first_name")
  lastName           String?   @db.VarChar(100) @map("last_name")
  displayName        String?   @db.VarChar(150) @map("display_name")
  avatarUrl          String?   @map("avatar_url")
  bio                String?
  phoneNumber        String?   @db.VarChar(20) @map("phone_number")
  gender             String?   @db.VarChar(30)
  dateOfBirth        DateTime? @map("date_of_birth") @db.Date
  school             String?   @db.VarChar(255)
  graduationYear     Int?      @map("graduation_year") @db.SmallInt
  prcRegistrationNo  String?   @db.VarChar(50) @map("prc_registration_no")
  examTargetDate     DateTime? @map("exam_target_date") @db.Date
  preferredLanguage  String    @default("en") @db.Char(5) @map("preferred_language")
  timezone           String    @default("Asia/Manila") @db.VarChar(50)
  studyGoalHours     Int?      @map("study_goal_hours") @db.SmallInt
  notificationsEmail Boolean   @default(true) @map("notifications_email")
  notificationsPush  Boolean   @default(true) @map("notifications_push")
  theme              String    @default("system") @db.VarChar(20)
  version            Int       @default(0)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([examTargetDate])
  @@index([school])
  @@map("user_profiles")
}

/// JWT refresh tokens, email verification, and password reset tokens.
model UserAuthToken {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @db.Uuid @map("user_id")
  tokenHash   String        @unique @db.VarChar(512) @map("token_hash")
  tokenType   AuthTokenType @map("token_type")
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz
  isRevoked   Boolean       @default(false) @map("is_revoked")
  revokedAt   DateTime?     @map("revoked_at") @db.Timestamptz
  userAgent   String?       @map("user_agent")
  ipAddress   String?       @map("ip_address")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("user_auth_tokens")
}

/// OAuth provider linkages per user (Google, Facebook, etc.)
model OauthAccount {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String        @db.Uuid @map("user_id")
  provider          OAuthProvider
  providerUserId    String        @db.VarChar(255) @map("provider_user_id")
  providerEmail     String?       @db.VarChar(320) @map("provider_email")
  accessTokenEnc    String?       @map("access_token_enc")
  refreshTokenEnc   String?       @map("refresh_token_enc")
  tokenExpiresAt    DateTime?     @map("token_expires_at") @db.Timestamptz
  scopes            String[]
  rawProfile        Json?         @map("raw_profile")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

/// TOTP multi-factor authentication configuration (1:1 with User).
model MfaConfig {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @db.Uuid @map("user_id")
  method         MfaMethod @default(totp)
  totpSecretEnc  String?   @map("totp_secret_enc")
  backupCodes    String[]  @map("backup_codes")
  isEnabled      Boolean   @default(false) @map("is_enabled")
  enabledAt      DateTime? @map("enabled_at") @db.Timestamptz
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_configs")
}

/// Immutable audit log of every login attempt (success and failure).
model LoginAttempt {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?          @db.Uuid @map("user_id")
  emailTried  String           @db.VarChar(320) @map("email_tried")
  ipAddress   String           @map("ip_address")
  userAgent   String?          @map("user_agent")
  succeeded   Boolean
  failReason  LoginFailReason? @map("fail_reason")
  attemptedAt DateTime         @default(now()) @map("attempted_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, attemptedAt])
  @@index([ipAddress, attemptedAt])
  @@index([emailTried, attemptedAt])
  @@map("login_attempts")
}

// ============================================================================
// MODULE 2: ROLES & PERMISSIONS (RBAC)
// ============================================================================

/// Named roles: free_user, subscriber, content_admin, super_admin.
model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(50)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  users           User[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

/// Granular platform capabilities. Slugs: module:resource:action.
model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(150)
  slug        String   @unique @db.VarChar(100)
  module      String   @db.VarChar(50)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

/// Junction: role ↔ permission (M:N).
model RolePermission {
  roleId       String   @db.Uuid @map("role_id")
  permissionId String   @db.Uuid @map("permission_id")
  grantedBy    String?  @db.Uuid @map("granted_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}


/// Multi-role assignment table: one user can hold multiple roles simultaneously.
/// The User.roleId FK is retained for JWT fast-path (primary role).
/// This table provides the extended permission surface queried at runtime.
/// Sprint 2.3: Replaces single-role-per-user for fine-grained RBAC.
model UserRole {
  userId     String    @db.Uuid @map("user_id")
  roleId     String    @db.Uuid @map("role_id")
  grantedBy  String?   @db.Uuid @map("granted_by")
  grantedAt  DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  isActive   Boolean   @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([userId, isActive])
  @@map("user_roles")
}

// ============================================================================
// MODULE 3: CONTENT TAXONOMY
// ============================================================================

/// Top-level CE examination subject areas.
model Subject {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @unique @db.VarChar(150)
  code             String   @unique @db.VarChar(20)
  examDay          Int      @map("exam_day") @db.SmallInt
  prcWeightPercent Decimal? @map("prc_weight_percent") @db.Decimal(5, 2)
  description      String?
  colorHex         String?  @db.Char(7) @map("color_hex")
  iconName         String?  @db.VarChar(50) @map("icon_name")
  sortOrder        Int      @default(0) @map("sort_order") @db.SmallInt
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  topics   Topic[]
  questions Question[]
  formulas  FormulaLibrary[]
  learningObjectives LearningObjective[] @relation("SubjectLearningObjectives")

  @@index([examDay])
  @@index([isActive])
  @@map("subjects")
}

/// Second-level taxonomy: subdivisions within a subject.
model Topic {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId          String   @db.Uuid @map("subject_id")
  name               String   @db.VarChar(200)
  code               String   @unique @db.VarChar(30)
  prcLearningOutcome String?  @map("prc_learning_outcome")
  prcWeightPercent   Decimal? @map("prc_weight_percent") @db.Decimal(5, 2)
  description        String?
  sortOrder          Int      @default(0) @map("sort_order") @db.SmallInt
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  subtopics Subtopic[]
  questions Question[]
  formulas  FormulaLibrary[]

  @@index([subjectId])
  @@index([subjectId, sortOrder])
  @@map("topics")
}

/// Finest granularity — atomic unit for adaptive learning.
model Subtopic {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicId   String   @db.Uuid @map("topic_id")
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(40)
  description String?
  keywords  String[]
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Restrict)
  questions Question[]

  @@index([topicId])
  @@index([topicId, sortOrder])
  @@map("subtopics")
}

/// Question difficulty tiers with psychometric thresholds.
model DifficultyLevel {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @unique @db.VarChar(50)
  code             Int      @unique @db.SmallInt
  description      String?
  passingThreshold Decimal  @default(70.00) @map("passing_threshold") @db.Decimal(5, 2)
  colorHex         String?  @db.Char(7) @map("color_hex")
  sortOrder        Int      @default(0) @map("sort_order") @db.SmallInt
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  questions Question[]

  @@map("difficulty_levels")
}

// ============================================================================
// MODULE 4: QUESTION BANK (Phase 2)
// ============================================================================

/// Master question record. Canonical content; satellite tables hold derived data.
model Question {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionCode       String         @unique @db.VarChar(30) @map("question_code")
  subjectId          String         @db.Uuid @map("subject_id")
  topicId            String         @db.Uuid @map("topic_id")
  subtopicId         String         @db.Uuid @map("subtopic_id")
  difficultyLevelId  String         @db.Uuid @map("difficulty_level_id")
  stemText           String         @map("stem_text")
  stemLatex          String?        @map("stem_latex")
  stemHtml           String?        @map("stem_html")
  correctChoice      String         @db.Char(1) @map("correct_choice")
  explanationText    String         @map("explanation_text")
  explanationLatex   String?        @map("explanation_latex")
  explanationHtml    String?        @map("explanation_html")
  questionStatus     QuestionStatus @default(draft) @map("question_status")
  bloomLevel         BloomLevel     @default(apply) @map("bloom_level")
  prcSyllabusRef     String?        @db.VarChar(100) @map("prc_syllabus_ref")
  learningObjective  String?        @map("learning_objective")
  boardWeight        Decimal?       @map("board_weight") @db.Decimal(5, 4)
  estSolvingTimeSec  Int            @default(90) @map("est_solving_time_sec") @db.SmallInt
  questionType       QuestionType   @default(multiple_choice) @map("question_type")
  prcYearAppeared    Int[]          @map("prc_year_appeared")
  keywords           String[]
  language           String         @default("en") @db.Char(5)
  authorId           String         @db.Uuid @map("author_id")
  reviewerId         String?        @db.Uuid @map("reviewer_id")
  publishedBy        String?        @db.Uuid @map("published_by")
  publishedAt        DateTime?      @map("published_at") @db.Timestamptz
  currentVersion     Int            @default(1) @map("current_version") @db.SmallInt
  isPrcVerified      Boolean        @default(false) @map("is_prc_verified")
  isAiGenerated      Boolean        @default(false) @map("is_ai_generated")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?      @map("deleted_at") @db.Timestamptz

  subject          Subject              @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  topic            Topic                @relation(fields: [topicId], references: [id], onDelete: Restrict)
  subtopic         Subtopic             @relation(fields: [subtopicId], references: [id], onDelete: Restrict)
  difficultyLevel  DifficultyLevel      @relation(fields: [difficultyLevelId], references: [id], onDelete: Restrict)
  author           User                 @relation("QuestionAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  reviewer         User?                @relation("QuestionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  publisher        User?                @relation("QuestionPublisher", fields: [publishedBy], references: [id], onDelete: SetNull)
  choices          QuestionChoice[]
  images           QuestionImage[]
  statistics       QuestionStatistics?
  aiContent        QuestionAiContent?
  intelligence     QuestionIntelligence?
  versions         QuestionVersion[]
  reviewWorkflow   QuestionReviewWorkflow[]
  questionTags     QuestionTag[]
  questionFormulas QuestionFormula[]
  references       QuestionReference[]
  codeReferences   QuestionCodeReference[]
  relatedFrom      QuestionRelated[]    @relation("RelatedFrom")
  relatedTo        QuestionRelated[]    @relation("RelatedTo")
  attempts         QuestionAttempt[]    @relation("QuestionAttempts")
  bookmarks        Bookmark[]           @relation("QuestionBookmarks")
  favorites        Favorite[]           @relation("QuestionFavorites")
  recentlyViewedBy RecentlyViewed[]     @relation("QuestionRecentlyViewed")
  examQuestions    ExamQuestion[]       @relation("QuestionExamQuestions")
  locks            QuestionLock[]
  reviewAssignments ReviewAssignment[]
  reviewComments   ReviewComment[]
  editorialNotes   EditorialNote[]

  @@index([subtopicId, difficultyLevelId])
  @@index([topicId])
  @@index([subjectId])
  @@index([questionStatus])
  @@index([authorId])
  @@index([publishedAt])
  @@map("questions")
}

/// The four answer choices for each question (A, B, C, D).
model QuestionChoice {
