  choiceLetter  String  @db.Char(1) @map("choice_letter")
  choiceText    String  @map("choice_text")
  choiceLatex   String? @map("choice_latex")
  choiceHtml    String? @map("choice_html")
  isCorrect     Boolean @default(false) @map("is_correct")
  choiceImageId String? @db.Uuid @map("choice_image_id")
