# =============================================================================
# CE Board Master — Test Environment Variables
# =============================================================================
# Copy to .env.test for running integration and E2E tests.
# Uses a SEPARATE test database to prevent data corruption.
# =============================================================================

NODE_ENV=test
PORT=3002
API_PREFIX=api/v1
APP_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3000

# SEPARATE test database (NEVER use the development database for tests)
DATABASE_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_test?schema=public
DATABASE_POOL_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_test?schema=public
DATABASE_ANALYTICS_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_test?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_DB_CACHE=3
REDIS_DB_QUEUE=4
REDIS_DB_SESSION=5
REDIS_DEFAULT_TTL=60

# Test JWT keys (not real keys — for testing only)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\ntest-key\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\ntest-key\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRES_IN=900
JWT_REFRESH_TOKEN_EXPIRES_IN=2592000

GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/v1/auth/google/callback

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
AWS_S3_BUCKET=ce-board-master-test
AWS_S3_PRESIGN_EXPIRY=900
CDN_DOMAIN=https://cdn.test.ce-boardmaster.ph

STRIPE_SECRET_KEY=sk_test_dummy_key_for_testing
STRIPE_WEBHOOK_SECRET=whsec_test_dummy
STRIPE_PRICE_BASIC_MONTHLY=price_test_basic_monthly
STRIPE_PRICE_BASIC_ANNUAL=price_test_basic_annual
STRIPE_PRICE_PRO_MONTHLY=price_test_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_test_pro_annual

PAYMONGO_SECRET_KEY=sk_test_dummy_paymongo
PAYMONGO_PUBLIC_KEY=pk_test_dummy_paymongo
PAYMONGO_WEBHOOK_SECRET=test_webhook_secret

ANTHROPIC_API_KEY=sk-ant-test-dummy
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1000
AI_TUTOR_DAILY_LIMIT=50

RESEND_API_KEY=re_test_dummy
EMAIL_FROM=noreply@test.ce-boardmaster.ph
EMAIL_FROM_NAME="CE Board Master Test"

RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_AUTH=100
RATE_LIMIT_PUBLIC=100

ARGON2_PEPPER=test-pepper-value-must-be-32-chars-min
COOKIE_SECRET=test-cookie-secret-must-be-32-chars

LOG_LEVEL=error
LOG_PRETTY=false

HEALTH_DB_THRESHOLD_MS=500
HEALTH_REDIS_THRESHOLD_MS=100

SWAGGER_ENABLED=false
SWAGGER_PATH=docs

QUEUE_CONCURRENCY_EMAIL=1
QUEUE_CONCURRENCY_ANALYTICS=1
QUEUE_CONCURRENCY_AI_CONTENT=1
