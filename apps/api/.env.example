# =============================================================================
# CE Board Master — API Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# NEVER commit .env to source control.
# All secrets must be stored in AWS Secrets Manager in staging/production.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
APP_NAME="CE Board Master API"
APP_VERSION=1.0.0

# API base URL (used for constructing links in emails, OAuth callbacks, etc.)
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL (AWS RDS in production)
# -----------------------------------------------------------------------------
# Direct connection string (used by Prisma CLI for migrations)
DATABASE_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_dev?schema=public

# Connection pool URL (used by application via PgBouncer in production)
# In development: same as DATABASE_URL
DATABASE_POOL_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_dev?schema=public&pool_timeout=10&connection_limit=10

# Analytics read replica (in development: same as primary)
DATABASE_ANALYTICS_URL=postgresql://ceboardmaster:password@localhost:5432/ceboardmaster_dev?schema=public

# -----------------------------------------------------------------------------
# REDIS — AWS ElastiCache in production
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
# Redis DB numbers for isolation
REDIS_DB_CACHE=0
REDIS_DB_QUEUE=1
REDIS_DB_SESSION=2

# Default TTL for cache entries (seconds)
REDIS_DEFAULT_TTL=300

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION — RS256 Asymmetric Keys
# -----------------------------------------------------------------------------
# In production: private key stored in AWS Secrets Manager
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRES_IN=900
JWT_REFRESH_TOKEN_EXPIRES_IN=2592000

# -----------------------------------------------------------------------------
# GOOGLE OAUTH 2.0
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# -----------------------------------------------------------------------------
# AWS — S3 Storage + CloudFront CDN
# -----------------------------------------------------------------------------
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ce-board-master-content-dev
AWS_S3_PRESIGN_EXPIRY=900
# CloudFront domain for serving stored files
CDN_DOMAIN=https://cdn.ce-boardmaster.ph

# -----------------------------------------------------------------------------
# STRIPE — Payment Processing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_BASIC_MONTHLY=price_basic_monthly_id
STRIPE_PRICE_BASIC_ANNUAL=price_basic_annual_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id

# -----------------------------------------------------------------------------
# PAYMONGO — Philippine Local Payments (GCash, Maya, Bank Transfer)
# -----------------------------------------------------------------------------
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_key
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_key
PAYMONGO_WEBHOOK_SECRET=your_paymongo_webhook_secret

# -----------------------------------------------------------------------------
# ANTHROPIC — Claude AI Tutor
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096
# Daily AI query limit per Pro user (enforced in Redis)
AI_TUTOR_DAILY_LIMIT=50

# -----------------------------------------------------------------------------
# RESEND — Transactional Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=noreply@ce-boardmaster.ph
EMAIL_FROM_NAME="CE Board Master"

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Global rate limit (requests per minute per authenticated user)
RATE_LIMIT_GLOBAL=120
# Auth endpoint rate limit (per minute per IP)
RATE_LIMIT_AUTH=10
# Unauthenticated endpoint rate limit (per minute per IP)
RATE_LIMIT_PUBLIC=20

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Pepper for Argon2id hashing (in production: from AWS Secrets Manager)
# Generate: openssl rand -hex 32
ARGON2_PEPPER=your-random-pepper-hex-string
# Session cookie secret
COOKIE_SECRET=your-random-cookie-secret-32-chars-min

# -----------------------------------------------------------------------------
# LOGGING — Pino
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
# Set to true to pretty-print logs (development only)
LOG_PRETTY=true

# -----------------------------------------------------------------------------
# HEALTH CHECK
# -----------------------------------------------------------------------------
# Threshold for database response time warning (ms)
HEALTH_DB_THRESHOLD_MS=200
# Threshold for Redis response time warning (ms)
HEALTH_REDIS_THRESHOLD_MS=50

# -----------------------------------------------------------------------------
# SWAGGER / API DOCS
# -----------------------------------------------------------------------------
# Set to false to disable Swagger in production
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# -----------------------------------------------------------------------------
# QUEUE — BullMQ
# -----------------------------------------------------------------------------
QUEUE_CONCURRENCY_EMAIL=5
QUEUE_CONCURRENCY_ANALYTICS=10
QUEUE_CONCURRENCY_AI_CONTENT=3
