# pnpm configuration for the CE Board Master monorepo.

# Allow `pnpm deploy` to work from the workspace (used by the API Docker build).
# Without this, deploy can refuse to run inside a workspace on newer pnpm.
force-legacy-deploy=true

# Hoist Prisma + its engines so the generated client resolves at runtime in the
# deployed bundle.
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*

# Reproducible installs in CI/containers.
strict-peer-dependencies=false
auto-install-peers=true
