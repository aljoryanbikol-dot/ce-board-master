# =============================================================================
# CE Board Master — Production Environment (TEMPLATE)
# =============================================================================
# Copy to .env.production (gitignored) and fill in real secrets via your secrets
# manager (AWS Secrets Manager / Doppler / Vercel env / GitHub Actions secrets).
# NEVER commit the filled file. Generate keys/secrets with strong entropy.
#   - JWT keys:  openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout
#   - secrets:   openssl rand -base64 48
# =============================================================================

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PREFIX=api/v1
APP_NAME=CE Board Master API
APP_VERSION=4.1.0
APP_URL=https://api.ceboardmaster.ph
FRONTEND_URL=https://ceboardmaster.ph
ADMIN_URL=https://ceboardmaster.ph/admin
CORS_ORIGINS=https://ceboardmaster.ph,https://www.ceboardmaster.ph

# ── Database (PostgreSQL — managed RDS / self-hosted) ──────────────────────────
# Use the pooled URL for the app, the direct URL for migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ceboardmaster_prod?schema=public&connection_limit=20&sslmode=require
DATABASE_POOL_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/ceboardmaster_prod?pgbouncer=true
DATABASE_ANALYTICS_URL=postgresql://READONLY_USER:PASSWORD@REPLICA_HOST:5432/ceboardmaster_prod?sslmode=require
# For docker-compose.prod.yml:
POSTGRES_USER=ceboardmaster
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ceboardmaster_prod

# ── Redis (ElastiCache / managed) ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_TLS=true
REDIS_DB_CACHE=0
REDIS_DB_QUEUE=1
REDIS_DB_SESSION=2
REDIS_DEFAULT_TTL=300

# ── Auth / JWT (RS256) ─────────────────────────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
COOKIE_SECRET=CHANGE_ME_LONG_RANDOM

# ── OAuth (Google) ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.ceboardmaster.ph/api/v1/auth/google/callback

# ── Object storage + CDN (AWS S3 + CloudFront) ─────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_DOMAIN=https://cdn.ceboardmaster.ph

# ── Payments ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
PAYMENT_DEFAULT_PROVIDER=paymongo
PAYMENT_GRACE_PERIOD_DAYS=3
PAYMENT_CURRENCY=PHP

# ── AI (Anthropic) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=2048
AI_TUTOR_DAILY_LIMIT=50

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@ceboardmaster.ph
EMAIL_FROM_NAME=CE Board Master

# ── Rate limits (requests/min) ─────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_PUBLIC=30

# ── Observability ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false
HEALTH_DB_THRESHOLD_MS=1000
HEALTH_REDIS_THRESHOLD_MS=500
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Swagger (disable in prod unless IP-restricted) ─────────────────────────────
SWAGGER_ENABLED=false
SWAGGER_PATH=docs

# ── Queues ─────────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY_EMAIL=5
QUEUE_CONCURRENCY_ANALYTICS=3
QUEUE_CONCURRENCY_AI_CONTENT=2

# ── Frontend (build-time public; set in Vercel) ────────────────────────────────
NEXT_PUBLIC_API_URL=/api/backend
NEXT_PUBLIC_APP_NAME=CE Board Master
API_PROXY_TARGET=https://api.ceboardmaster.ph
