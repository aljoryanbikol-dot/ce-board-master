# CE Board Master — commit-msg hook.
# Validates the commit message against Conventional Commits via commitlint.
# Uses `pnpm exec` (not npx) because npx mis-quotes paths containing spaces on
# Windows (e.g. "C:\Users\Gavino Family\...") and fails with
# "'C:\Users\Gavino' is not recognized as an internal or external command".
pnpm exec commitlint --edit "$1"
