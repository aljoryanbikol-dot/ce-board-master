# CE Board Master — pre-commit hook.
# Lints changed packages (blocking). Type-checks too, but only as an ADVISORY
# step: a typecheck failure prints a warning and does NOT block the commit, so
# pre-existing type errors can't make committing impossible on a dev machine.
# Strict type checking still runs in CI / build.
#
# Windows note: this hook runs under Git Bash (sh), and every command goes through
# `pnpm exec` rather than `npx`, because npx mis-quotes paths containing spaces on
# Windows (e.g. "C:\Users\Gavino Family\...") and fails with
# "'C:\Users\Gavino' is not recognized as an internal or external command".

pnpm exec turbo run lint --filter='[HEAD]' --concurrency=4

# Advisory type-check. The leading `if !` keeps `sh -e` from aborting the hook
# when typecheck exits non-zero, so the commit is never blocked by type errors.
if ! pnpm exec turbo run typecheck --filter='[HEAD]' --concurrency=4; then
  echo "warning: typecheck reported errors (advisory only — commit not blocked)."
  echo "         Run 'pnpm typecheck' to see and fix them before pushing."
fi
